<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Place Order — Ecommerce Lite</title>
  <style>
    body { font-family: Arial, sans-serif; max-width: 500px; margin: 40px auto; padding: 0 20px; }
    nav { margin-bottom: 30px; }
    nav a { margin-right: 20px; text-decoration: none; color: #333; font-weight: bold; }
    input, select { width: 100%; padding: 10px; margin: 8px 0 16px;
                    box-sizing: border-box; border: 1px solid #ddd; border-radius: 4px; }
    button { background: #0066cc; color: white; padding: 10px 24px;
             border: none; border-radius: 4px; cursor: pointer; }
    button:hover { background: #0052a3; }
    .message { padding: 12px; border-radius: 4px; margin-bottom: 20px;
               background: #f0f7ff; border: 1px solid #cce0ff; color: #004499; }
    .trace-id { margin-top: 40px; font-size: 0.75em; color: #999; }
  </style>
</head>
<body>

  <nav>
    <a href="/">Products</a>
    <a href="/register">Register</a>
    <a href="/order">Place Order</a>
  </nav>

  <h1>Place Order</h1>

  <% if (message) { %>
    <div class="message"><%= message %></div>
  <% } %>

  <form method="POST" action="/order">

    <label>User ID</label>
    <input type="number" name="user_id" required placeholder="Enter your user ID">

    <label>Product</label>
    <select name="product_id" required>
      <% products.forEach(product => { %>
        <option value="<%= product.id %>">
          <%= product.name %> — ₹<%= product.price %> (Stock: <%= product.stock %>)
        </option>
      <% }) %>
    </select>

    <label>Quantity</label>
    <input type="number" name="quantity" required min="1" value="1">

    <button type="submit">Place Order</button>

  </form>

  <p class="trace-id">Request ID: <%= request_id %></p>

</body>
</html>