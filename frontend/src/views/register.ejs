<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Register — Ecommerce Lite</title>
  <style>
    body { font-family: Arial, sans-serif; max-width: 500px; margin: 40px auto; padding: 0 20px; }
    nav { margin-bottom: 30px; }
    nav a { margin-right: 20px; text-decoration: none; color: #333; font-weight: bold; }
    input { width: 100%; padding: 10px; margin: 8px 0 16px; box-sizing: border-box; border: 1px solid #ddd; border-radius: 4px; }
    button { background: #0066cc; color: white; padding: 10px 24px; border: none; border-radius: 4px; cursor: pointer; }
    button:hover { background: #0052a3; }
    .message { padding: 12px; border-radius: 4px; margin-bottom: 20px;
               background: #f0f7ff; border: 1px solid #cce0ff; color: #004499; }
    .trace-id { margin-top: 40px; font-size: 0.75em; color: #999; }
  </style>
</head>
<body>

  <nav>
    <a href="/">Products</a>
    <a href="/register">Register</a>
    <a href="/order">Place Order</a>
  </nav>

  <h1>Register</h1>

  <% if (message) { %>
    <div class="message"><%= message %></div>
  <% } %>

  <form method="POST" action="/register">
    <label>Name</label>
    <input type="text" name="name" required placeholder="Your name">

    <label>Email</label>
    <input type="email" name="email" required placeholder="your@email.com">

    <button type="submit">Register</button>
  </form>

  <p class="trace-id">Request ID: <%= request_id %></p>

</body>
</html>